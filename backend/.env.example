# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=MyWorker
APP_ENV=development
SECRET_KEY=change-me-to-a-secure-random-string-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://myworker:myworker@localhost:5432/myworker

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── M-Pesa (Safaricom Daraja) ────────────────────────────────────────────────
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://your-domain.com/api/v1/invoices/mpesa-callback
MPESA_ENV=sandbox

# ─── Email (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxx...
EMAIL_FROM=noreply@myworker.ai
EMAIL_FROM_NAME=MyWorker Agency

# ─── WhatsApp Business (Meta Cloud API) ──────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=myworker_wh_verify_2024
WHATSAPP_APP_SECRET=
WHATSAPP_AUTO_REPLY=true

# ─── Social Media APIs ────────────────────────────────────────────────────────
# Meta (Facebook + Instagram)
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_USER_ID=

# LinkedIn
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# TikTok
TIKTOK_ACCESS_TOKEN=

# Twitter / X
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ─── Netlify Deployment ───────────────────────────────────────────────────────
NETLIFY_ACCESS_TOKEN=

# ─── Vercel Deployment ────────────────────────────────────────────────────────
VERCEL_ACCESS_TOKEN=

# ─── WordPress (default / fallback) ──────────────────────────────────────────
WP_DEFAULT_URL=https://your-wp-site.com
WP_DEFAULT_USER=admin
WP_DEFAULT_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ─── Agency Settings ──────────────────────────────────────────────────────────
AGENCY_NAME=MyWorker Digital Agency
AGENCY_EMAIL=contact@myworker.ai
LEAD_SCAN_INTERVAL_MINUTES=30
POST_SCHEDULE_HOUR=9
POST_SCHEDULE_MINUTE=0
